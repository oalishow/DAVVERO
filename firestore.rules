rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin(appId) {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'admblackjamf@gmail.com') ||
        (exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)) &&
         'role' in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)).data.role == 'SUPER_ADMIN')
      );
    }

    function isAdmin(appId) {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'admblackjamf@gmail.com') || 
        (exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)) && 
         'role' in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN']) ||
        (exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/students/$(request.auth.uid)) && 
         'roles' in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/students/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/artifacts/$(appId)/public/data/students/$(request.auth.uid)).data.roles is list &&
         get(/databases/$(database)/documents/artifacts/$(appId)/public/data/students/$(request.auth.uid)).data.roles.hasAny(['ADMIN', 'DIRETORIA', 'GESTÃO', 'COMUNICAÇÃO', 'SECRETARIA', 'admin', 'diretoria', 'gestão', 'comunicação', 'secretaria']))
      );
    }

    function isGerente(appId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)) && 
        'role' in get(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)).data &&
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/administrators/$(request.auth.uid)).data.role == 'GERENTE'
      );
    }

    // Root Collections
    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /artifacts/{appId}/public/data {
      
      // Mural Posts
      match /mural_posts/{postId} {
        allow read: if true;
        
        // Creation rules
        allow create: if isSignedIn() && (
          // Data validation
          request.resource.data.text is string &&
          // Force pending status for non-admins
          (isAdmin(appId) || isGerente(appId) || request.resource.data.status == 'pending')
        );

        // Update rules
        allow update: if isSignedIn() && (
          // Admin can update anything (approve, pin, etc.)
          isAdmin(appId) || isGerente(appId) || 
          (
            // Users can update their own posts
            true && // Relaxed rule to allow frontend local storage based auth
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollOptions', 'votedUserIds', 'voterDetails', 'text', 'likes', 'commentsCount'])
          ) ||
          (
            // Any signed in user can like, unlike, comment, or vote
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentsCount']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollOptions', 'votedUserIds', 'voterDetails']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount'])
          )
        );

        // Delete rules
        allow delete: if isAdmin(appId) || isGerente(appId) || isSignedIn();

        // Comments Subcollection
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow update: if isAdmin(appId) || isGerente(appId) || isSignedIn();
          allow delete: if isAdmin(appId) || isGerente(appId) || isSignedIn();
        }
      }

      // Students/Members
      match /students/{studentId} {
        allow read: if true; // Public directory
        allow create: if true;
        allow update, delete: if true;
      }

      // Events
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin(appId) || isGerente(appId);
      }

      // Attendances
      match /attendances/{attId} {
        allow read: if true;
        allow write: if true;
      }

      // Availabilities
      match /availabilities/{availId} {
        allow read: if true;
        allow write: if true;
      }

      // Appointments
      match /appointments/{apptId} {
        allow read: if true;
        allow write: if true;
      }

      // Administrators
      match /administrators/{adminId} {
        allow read: if isSignedIn();
        allow create: if isAdmin(appId) || (isSignedIn() && request.auth.uid == adminId);
        allow update: if isAdmin(appId) || (isSignedIn() && request.auth.uid == adminId && 
          (!('role' in request.resource.data.diff(resource.data).affectedKeys()) || request.resource.data.role == resource.data.role));
        allow delete: if isAdmin(appId);
      }

      // Admin Invites
      match /admin_invites/{inviteEmail} {
        allow read: if true;
        allow write: if isAdmin(appId) || isSignedIn();
      }

      // Audit Logs
      match /audit_logs/{logId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Push Subscriptions
      match /push_subscriptions/{subId} {
        allow read, write: if true;
      }
      
      // Notifications
      match /notifications/{notifId} {
        allow read: if isSignedIn();
        allow write: if true;
      }
    }
  }
}
