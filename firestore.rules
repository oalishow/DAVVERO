rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin(appId) {
      // Check if user has an admin role in the students collection or is the dedicated admin account
      // Note: This relies on the structure of your students collection
      return isSignedIn() && (
        request.auth.token.email == 'admblackjamf@gmail.com' || 
        (exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/students/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/artifacts/$(appId)/public/data/students/$(request.auth.uid)).data.roles.hasAny(['ADMIN', 'DIRETORIA', 'GESTÃO', 'admin', 'diretoria', 'gestão']))
      );
    }

    // Root Collections
    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    match /artifacts/{appId}/public/data {
      
      // Mural Posts
      match /mural_posts/{postId} {
        // Anyone can read approved posts. Admins and owners can read everything.
        allow read: if resource.data.status == 'approved' || isAdmin(appId) || (isSignedIn() && resource.data.authorId == request.auth.uid);
        
        // Creation rules
        allow create: if isSignedIn() && (
          // Data validation
          request.resource.data.text is string &&
          // Force pending status for non-admins
          (isAdmin(appId) || request.resource.data.status == 'pending')
        );

        // Update rules
        allow update: if isSignedIn() && (
          // Admin can update anything (approve, pin, etc.)
          isAdmin(appId) || 
          (
            // Users can update their own posts
            (resource.data.authorId == request.auth.uid || true) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollOptions', 'votedUserIds', 'text', 'likes', 'commentsCount'])
          ) ||
          (
            // Any signed in user can like, unlike, comment, or vote
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentsCount']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollOptions', 'votedUserIds']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount'])
          )
        );

        // Delete rules
        allow delete: if isAdmin(appId) || isSignedIn();

        // Comments Subcollection
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow update: if isAdmin(appId) || (isSignedIn() && resource.data.authorId == request.auth.uid) || true;
          allow delete: if isAdmin(appId) || (isSignedIn() && resource.data.authorId == request.auth.uid) || true;
        }
      }

      // Students/Members
      match /students/{studentId} {
        allow read: if true; // Public directory
        allow write: if isAdmin(appId) || (isSignedIn() && request.auth.uid == studentId);
      }

      // Events
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin(appId);
      }

      // Attendances
      match /attendances/{attId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // Availabilities
      match /availabilities/{availId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // Appointments
      match /appointments/{apptId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // Push Subscriptions
      match /push_subscriptions/{subId} {
        allow read, write: if true;
      }
      
      // Notifications
      match /notifications/{notifId} {
        allow read: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'todos');
        allow write: if isAdmin(appId);
        allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      }
    }
  }
}
